# REQUIRED: Real hosted PostgreSQL connection string.
# Do not leave this placeholder value. Signup/login cannot work without a real database.
# Good providers: Supabase Postgres, Neon, Railway Postgres, Prisma Postgres.
# Many hosted providers require sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require"

# Optional. Change this if you run multiple apps on the same domain.
SESSION_COOKIE_NAME="resume_ats_session"

# Local development URL. In Netlify, set both values to your live URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Google Sign-In. Leave blank until you create a Google OAuth Client.
# When blank, the app disables the Google button instead of showing a broken authorization screen.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Gemini AI Resume Generator.
# Without this key, the AI generator still works with a simple built-in fallback.
# Add your Google AI Studio key for stronger voice/text understanding.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
